<Window x:Class="Ornytolog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ornytolog"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800">
    <Grid>
        <StackPanel>
            <DataGrid
                Height="200"
                Margin="20"
                AutoGenerateColumns="False"
                HeadersVisibility="Column"
                ItemsSource="{Binding Birds}"
                SelectedItem="{Binding SelectedBird}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding Id}"
                        FontSize="16"
                        Header="ID" />
                    <DataGridTextColumn
                        Binding="{Binding Name}"
                        FontSize="16"
                        Header="Имя" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Margin="20">
                <TextBlock FontSize="20" Text="Имя" />
                <TextBox FontSize="20" Text="{Binding Name}" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button
                    Margin="10"
                    Command="{Binding AddBirdCommand}"
                    Content="Add Bird"
                    FontSize="20" />
                <Button
                    Margin="10"
                    Command="{Binding EditBirdCommand}"
                    Content="Edit Bird"
                    FontSize="20" />
                <Button
                    Margin="10"
                    Command="{Binding DeleteBirdCommand}"
                    Content="Delete Bird"
                    FontSize="20" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
